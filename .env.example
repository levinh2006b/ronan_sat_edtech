MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?appName=<app-name>
LOCAL_MONGODB_URI=mongodb://127.0.0.1:27017/ronansat-local
# Optional override used by `bun run db -- --fetch`
REMOTE_MONGODB_URI=
# Requires `supabase login` plus the production database password for `bun run db -- --fetch`
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=afmeruhjbgqeebczpxzf
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<local-or-cloud-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<local-or-cloud-service-role-key>
GEMINI_API_KEY=<your-gemini-api-key>

# Cloudflare R2 (private flattened PDFs)
R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ENDPOINT=https://<cloudflare-account-id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=<private-pdf-bucket-name>

# Email
EMAIL_USER=<your-email-address>
EMAIL_PASS=<your-gmail-app-password>
EMAIL_FROM_NAME=Bluebook Support

# Public frontend config
NEXT_PUBLIC_DESMOS_URL=https://www.desmos.com/api/v1.9/calculator.js?apiKey=<desmos-api-key>
NEXT_PUBLIC_POSTHOG_KEY=<posthog-project-api-key>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google OAuth
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
