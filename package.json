{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- tsx scripts/dev.ts",
    "dev:secure": "bun run dev",
    "db": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- tsx scripts/db.ts",
    "stop": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- tsx scripts/stop.ts",
    "supabase:start": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- supabase start",
    "supabase:stop": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- supabase stop",
    "supabase:db:reset": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- tsx scripts/supabase/resetLocalDb.ts",
    "supabase:db:push:production": "dotenvx run -f .env.production --ignore=MISSING_ENV_FILE -- tsx scripts/supabase/pushProductionDb.ts",
    "supabase:migrate:users": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- tsx scripts/migrations/mongodb-to-supabase/migrateUsersToSupabase.ts",
    "supabase:migrate:tests": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- tsx scripts/migrations/mongodb-to-supabase/migrateTestsAndQuestionsToSupabase.ts",
    "supabase:migrate:user-data": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- tsx scripts/migrations/mongodb-to-supabase/migrateUserDataToSupabase.ts",
    "supabase:migrate:results": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- tsx scripts/migrations/mongodb-to-supabase/migrateResultsToSupabase.ts",
    "supabase:migrate:legacy-runtime": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- tsx scripts/migrations/mongodb-to-supabase/migrateLegacyBoardAndStudentsToSupabase.ts",
    "supabase:migrate:all": "dotenvx run -f .env.local -f .env.development --ignore=MISSING_ENV_FILE -- tsx scripts/migrations/mongodb-to-supabase/runAll.ts",
    "decrypt:production": "dotenvx decrypt -f .env.production --stdout",
    "decrypt:development": "dotenvx decrypt -f .env.development --stdout",
    "build": "dotenvx run -f .env.production --ignore=MISSING_ENV_FILE -- next build",
    "build:secure": "bun run build",
    "build:next": "next build",
    "start": "dotenvx run -f .env.production --ignore=MISSING_ENV_FILE -- next start",
    "start:secure": "bun run start",
    "lint": "eslint --no-error-on-unmatched-pattern --no-warn-ignored app components hooks lib types utils",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@next/third-parties": "^16.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "antd": "^6.3.6",
    "axios": "^1.15.0",
    "framer-motion": "^12.38.0",
    "html2pdf.js": "^0.14.0",
    "katex": "^0.16.45",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.1",
    "mongodb": "^7.1.1",
    "mongoose": "^9.4.1",
    "next": "16.2.4",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "posthog-js": "^1.369.3",
    "qrcode": "^1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hot-toast": "^2.6.0",
    "react-latex-next": "^3.0.0",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.61.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "conventional-changelog-cli": "^5.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.4",
    "supabase": "^2.92.1",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "description": "Ronan SAT edtech platform",
  "main": "stress-test.js",
  "directories": {
    "lib": "lib"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/levinh2006b/ronan_sat_edtech.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/levinh2006b/ronan_sat_edtech/issues"
  },
  "homepage": "https://github.com/levinh2006b/ronan_sat_edtech#readme"
}
